{
  "manifest_version": 3,
  "name": "Browser Workspace",
  "version": "1.0.0",
  "description": "Удобный менеджер рабочих пространств с сохранением сессий и боковой панелью.",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "windows",
    "favicon"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Открыть Browser Workspace"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}